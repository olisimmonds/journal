# Copy this file to `.env` and fill in your own values.
# See README.md -> "Google Drive setup" for how to obtain these.
#
# This is an OAuth 2.0 *client ID*, not a secret. It identifies your app to
# Google and is safe to ship in a public client-side bundle — it grants no
# access on its own and is validated against the authorized origins you
# configure in Google Cloud Console.
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# This IS normally a secret — for a typical multi-user public app it must
# never ship to the client. This app deliberately embeds it anyway so it can
# get a real refresh token (persistent Drive access, no repeated sign-in)
# with no backend server to hold it safely. That trade-off only makes sense
# for a single-user app with a narrow `drive.file` scope — see README.md ->
# "Data & privacy" before reusing this pattern elsewhere.
VITE_GOOGLE_CLIENT_SECRET=your-client-secret
